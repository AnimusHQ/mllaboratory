#!/usr/bin/env bash
# Guardrail policy switchboard.
# Flip via reviewed PR only.

# 0 = visibility mode in PR CI, 1 = enforce fail mode in PR CI.
ANIMUS_PR_LEGACY_ENFORCE=0
ANIMUS_PR_SUBMODULE_ENFORCE=0

# Nightly / release policy defaults.
ANIMUS_NIGHTLY_LEGACY_ENFORCE=1
ANIMUS_NIGHTLY_SUBMODULE_ENFORCE=1
ANIMUS_RELEASE_SUBMODULE_ENFORCE=1

# Metadata (optional, documentation only):
# ANIMUS_PR_LEGACY_ENFORCE_OWNER=release-engineering
# ANIMUS_PR_LEGACY_ENFORCE_TARGET=v1.2
